# Global FDI Monitor — Environment Variables
# Copy to .env.local for development, set as secrets in GitHub/Azure for production

# ── API ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── DATABASE ──────────────────────────────────────────────────────────────
# Azure PostgreSQL 16
DATABASE_URL=postgresql://fdiuser:PASSWORD@HOST.postgres.database.azure.com:5432/gfm

# ── CACHE ─────────────────────────────────────────────────────────────────
# Azure Redis Cache
REDIS_URL=rediss://:KEY@HOST.redis.cache.windows.net:6380

# ── AUTH ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 64
JWT_SECRET=your-64-char-secret-here

# ── STRIPE ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_MONTHLY_PRICE=price_...
STRIPE_PRO_ANNUAL_PRICE=price_...
STRIPE_ENT_ANNUAL_PRICE=price_...

# ── AI ────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── FRONTEND ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://fdi-backend-api.gentleglacier-ae9701ca.uaenorth.azurecontainerapps.io
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
