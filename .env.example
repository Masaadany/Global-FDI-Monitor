# GFM — Environment Variables Template
# Copy to .env and fill in values before deploying

# ── REQUIRED ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://fdiuser:CHANGE_ME@host.postgres.database.azure.com/gfm?sslmode=require
REDIS_URL=rediss://:CHANGE_ME@host.redis.cache.windows.net:6380
JWT_SECRET=CHANGE_ME_minimum_32_characters_long_secret_key

# ── PAYMENTS ──────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PRICE_PRO_MONTHLY=price_CHANGE_ME
STRIPE_PRICE_PRO_ANNUAL=price_CHANGE_ME
STRIPE_PRICE_FIC_50=price_CHANGE_ME
STRIPE_PRICE_FIC_100=price_CHANGE_ME
STRIPE_PRICE_FIC_500=price_CHANGE_ME

# ── AI & COMMS ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
RESEND_API_KEY=re_CHANGE_ME
FROM_EMAIL=noreply@fdimonitor.org

# ── FRONTEND ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.fdimonitor.org
NEXT_PUBLIC_AGENT_API=https://agents.fdimonitor.org
NEXT_PUBLIC_PREVIEW_PASSWORD=GFM2026PREVIEW

# ── SERVER ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
AGENT_SERVER_MODE=true
AGENT_PORT=8080

# ── OPTIONAL ──────────────────────────────────────────────────────────────
SENTRY_DSN=https://CHANGE_ME@sentry.io/CHANGE_ME
LOG_LEVEL=info
